<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NetworkService.Views"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="900" Background="#F4F6F9">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="15" Margin="0,0,10,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="#BDC3C7" Opacity="0.5" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Add New Road Entity" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                <TextBlock Text="ID:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,5,0,2"/>
                <TextBox Text="{Binding NewRoadId, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Name:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,5,0,2"/>
                <TextBox Text="{Binding NewRoadName, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Road Type:" FontWeight="SemiBold" Foreground="#34495E" Margin="0,5,0,2"/>
                <ComboBox ItemsSource="{Binding RoadTypes}" SelectedItem="{Binding SelectedRoadType}" DisplayMemberPath="Name" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

                <Button Command="{Binding AddRoadCommand}" Content="Add Entity" Height="35" Background="#2ECC71" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0" ItemsSource="{Binding Roads}" SelectedItem="{Binding SelectedRoad}" AutoGenerateColumns="False" IsReadOnly="True" Background="White" RowBackground="#F9F9F9" AlternatingRowBackground="White" BorderBrush="#BDC3C7">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="80"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type.Name}" Width="120"/>
                    <DataGridTextColumn Header="Current Value" Binding="{Binding Value}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <Button Grid.Row="1" Command="{Binding DeleteRoadCommand}" Content="Delete Selected Entity" HorizontalAlignment="Right" Width="180" Height="35" Margin="0,10,0,0" Background="#E74C3C" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </Grid>
    </Grid>
</UserControl>