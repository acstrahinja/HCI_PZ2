<UserControl x:Class="NetworkService.Views.NetworkDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:NetworkService.ViewModel"
             xmlns:model="clr-namespace:NetworkService.Model"
             mc:Ignorable="d" 
             d:DesignHeight="550" d:DesignWidth="780" Background="#F4F6F9">

    <UserControl.Resources>
        <Style x:Key="HelpTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontSize" Value="11"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsHelpEnabled, RelativeSource={RelativeSource AncestorType=Window}}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="5" Padding="10" Margin="0,0,10,0" BorderBrush="#BDC3C7" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TreeView" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#2C3E50"/>

                <TreeView Grid.Row="1" ItemsSource="{Binding TreeViewItems}"
                          PreviewMouseLeftButtonDown="TreeView_PreviewMouseLeftButtonDown"
                          MouseMove="TreeView_MouseMove"
                          BorderThickness="0">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:RoadTypeGroup}" ItemsSource="{Binding Roads}">
                            <StackPanel Orientation="Horizontal" Margin="2">
                                <TextBlock Foreground="#2C3E50" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#2C3E50"/>
                                <TextBlock Text=" Putevi" FontWeight="Bold" Foreground="#2C3E50"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>

                        <DataTemplate DataType="{x:Type model:RoadEntity}">
                            <StackPanel Orientation="Horizontal" Margin="5,2,2,2">
                                <TextBlock Text="{Binding Name}" Foreground="#2C3E50" VerticalAlignment="Center"/>

                                <TextBlock Text=" [ALARM]" Foreground="#E74C3C" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInAlarm}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </TreeView.Resources>
                </TreeView>

                <TextBlock Grid.Row="2" Style="{StaticResource HelpTextStyle}" 
                           Text="ToolTip: Drag entity to grid slot. Left-click two occupied slots to connect them with a line. Right-click to clear." 
                           TextWrapping="Wrap" Margin="5,10,5,5"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="White" CornerRadius="5" Padding="15" BorderBrush="#BDC3C7" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="Drag&amp;Drop network" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#2C3E50"/>

                    <Button Content="↩ Undo" Width="70" Height="25" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="#34495E" Foreground="White" FontWeight="SemiBold" FontSize="12" BorderThickness="0"
                            Command="{Binding UndoCommand}">
                        <Button.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2C3E50"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <Grid Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Lines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Background="Transparent" IsHitTestVisible="False"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Line X1="{Binding X1}" Y1="{Binding Y1}" X2="{Binding X2}" Y2="{Binding Y2}" 
                                      Stroke="#34495E" StrokeThickness="2.5" StrokeDashArray="2 1"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding CanvasSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="4" Columns="3" Background="Transparent"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="SlotBorder" 
                                        BorderBrush="#BDC3C7" 
                                        BorderThickness="1" 
                                        Margin="8" 
                                        Background="#E0E0E0" 
                                        CornerRadius="0" 
                                        AllowDrop="True" 
                                        Drop="Canvas_Drop" 
                                        DragOver="Canvas_DragOver" 
                                        Tag="{Binding Path=(ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}}">

                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="RightClick" 
                                                      Command="{Binding DataContext.FreeSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=Tag}"/>

                                        <MouseBinding MouseAction="LeftClick" 
                                                      Command="{Binding DataContext.ConnectSlotsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=Tag}"/>
                                    </Border.InputBindings>

                                    <Grid>
                                        <TextBlock Text="FREE" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#7F8C8D" FontSize="13" FontWeight="SemiBold" Visibility="{Binding IsFreeVisibility}"/>

                                        <Grid Visibility="{Binding IsOccupiedVisibility}" Margin="5" Background="Transparent"
                                              PreviewMouseLeftButtonDown="CanvasSlot_PreviewMouseLeftButtonDown"
                                              MouseMove="TreeView_MouseMove">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="2,0,2,0">
                                                <TextBlock x:Name="AlarmLabel" Text="[ALARM]" Foreground="#C0392B" FontWeight="Bold" FontSize="11" HorizontalAlignment="Left" VerticalAlignment="Center" Visibility="Collapsed"/>

                                                <Button Content="✕" Width="18" Height="18" HorizontalAlignment="Right" Background="#E74C3C" Foreground="White" FontWeight="Bold" FontSize="10" BorderThickness="0"
                                                        Command="{Binding DataContext.FreeSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=Tag}">
                                                    <Button.Resources>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>
                                            </Grid>

                                            <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,5,0,5">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                                        <TextBlock Text="ID: " FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                        <TextBlock Text="{Binding Road.ID}" FontSize="11" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                        <TextBlock Text=" | " FontSize="11" Foreground="#7F8C8D"/>
                                                        <TextBlock Text="{Binding Road.Name}" FontSize="11" FontWeight="Bold" Foreground="#2C3E50"/>
                                                    </StackPanel>

                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="Value: " FontSize="11" Foreground="#34495E"/>
                                                        <TextBlock Text="{Binding Road.Value}" FontSize="11" FontWeight="Bold" Foreground="#2C3E50"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Road.IsInAlarm}" Value="True">
                                        <Setter TargetName="SlotBorder" Property="Background" Value="#FFD6D6"/>
                                        <Setter TargetName="SlotBorder" Property="BorderBrush" Value="#E74C3C"/>
                                        <Setter TargetName="SlotBorder" Property="BorderThickness" Value="2"/>
                                        <Setter TargetName="AlarmLabel" Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>

                        <ItemsControl.AlternationCount>12</ItemsControl.AlternationCount>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>