<Window x:Class="NetworkService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetworkService.ViewModel"
        mc:Ignorable="d"
        Title="Traffic Monitoring System v1.0" Height="650" Width="1000" Background="#F4F6F9">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="E" Modifiers="Ctrl" 
                    Command="{Binding NavigationCommand}" 
                    CommandParameter="entities"/>

        <KeyBinding Key="D" Modifiers="Ctrl" 
                    Command="{Binding NavigationCommand}" 
                    CommandParameter="display"/>

        <KeyBinding Key="G" Modifiers="Ctrl" 
                    Command="{Binding NavigationCommand}" 
                    CommandParameter="graph"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="15,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20*"/>
                    <ColumnDefinition Width="0*"/>
                    <ColumnDefinition Width="7*"/>
                    <ColumnDefinition Width="458*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Traffic Monitoring System" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Grid.ColumnSpan="4"/>
                <TextBlock Text="Profile: John Smith" Foreground="#BDC3C7" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="3" Margin="374,0,0,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#34495E" Padding="10">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="NAVIGATION" Foreground="#ECF0F1" FontSize="12" FontWeight="Bold" Margin="5,10,0,15" Opacity="0.6"/>

                        <Button Command="{Binding NavigationCommand}" CommandParameter="entities" Content="Entities (CTRL+E)" Height="40" Margin="0,0,0,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>
                        <Button Command="{Binding NavigationCommand}" CommandParameter="display" Content="Network Display (CTRL+D)" Height="40" Margin="0,0,0,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>
                        <Button Command="{Binding NavigationCommand}" CommandParameter="graph" Content="Measurement Graph (CTRL+G)" Height="40" Margin="0,0,0,5" Background="Transparent" Foreground="White" BorderThickness="0" HorizontalContentAlignment="Left" Padding="10,0"/>
                    </StackPanel>

                    <Button Command="{Binding ToggleHelpCommand}" VerticalAlignment="Bottom" Height="40" BorderThickness="0" FontWeight="Bold">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E67E22"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Content" Value="DISABLE HELP"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHelpEnabled}" Value="False">
                                        <Setter Property="Background" Value="#2ECC71"/>
                                        <Setter Property="Content" Value="ENABLE HELP"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="10"/>
        </Grid>
    </Grid>
</Window>